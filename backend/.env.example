# Database Configuration (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.xxxxx:xxxxx@aws-x-xx-xxxx-x.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:xxxxx@aws-x-xx-xxxx-x.pooler.supabase.com:5432/postgres"

# Encryption Key (Generate using: openssl rand -hex 32)
ENCRYPTION_KEY="your-encryption-key-here"

# Server Configuration
PORT=4000

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176
